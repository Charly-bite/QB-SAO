# ============================================================
# Open-OMS — Environment Configuration
# Copy this file to .env and fill in the values.
# ============================================================

# Flask Environment: development | staging | production
FLASK_ENV=development

# Secret key (auto-generated if omitted in development)
SECRET_KEY=

# ---- SAP HANA Connection (read-only) -----------------------
SAP_HOST=20.0.1.9
SAP_PORT=30015
SAP_SCHEMA=SBO_QUIMICABOSS
SAP_USER=
SAP_PASS=

# ---- SQL Server (local persistence) ------------------------
SQL_SERVER=192.168.2.237
SQL_DATABASE=SGA_Database
SQL_USER=
SQL_PASSWORD=

# ---- Monitor (public dashboard) ----------------------------
# Leave empty for open access, or set a token to protect the API
MONITOR_TOKEN=

# ---- SGA Integration (label print webhook) ------------------
# Shared secret for SGA → Open-OMS API calls.
# If empty, the /orders/api/sga/* endpoints are DISABLED (503).
SGA_API_KEY=

# ---- Weather widget (optional) -----------------------------
OPENWEATHER_API_KEY=
WEATHER_CITY=Guadalajara,MX
